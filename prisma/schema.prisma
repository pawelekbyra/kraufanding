generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(uuid())
  clerkUserId      String              @unique
  email            String              @unique
  tier             UserTier            @default(FREE)
  role             SystemRole          @default(USER)
  isSubscribed     Boolean             @default(false)
  isPatron         Boolean             @default(false)
  stripeCustomerId String?             @unique
  imageUrl         String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  creators         Creator[]
  donations        Donation[]
  payments         Payment[]
  tips             Tip[]
  subscriptions    Subscription[]
  projectAccess    UserProjectAccess[]
  projectLikes     ProjectLike[]
  comments         Comment[]
  commentLikes     CommentLike[]
}

model Creator {
  id              String    @id @default(uuid())
  userId          String
  slug            String    @unique
  name            String
  bio             String?
  isApproved      Boolean   @default(false)
  stripeConnectId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  projects        Project[]
}

model Project {
  id              String              @id @default(uuid())
  creatorId       String
  title           String
  slug            String              @unique
  views           Int                 @default(0)
  status          String              @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  payments        Payment[]
  posts           Post[]
  creator         Creator             @relation(fields: [creatorId], references: [id])
  projectAccess   UserProjectAccess[]
  projectLikes    ProjectLike[]
  files           ProjectFile[]
}

model ProjectLike {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([projectId])
}

model ProjectFile {
  id        String   @id @default(uuid())
  projectId String
  path      String   @unique
  url       String
  minTier   Int      @default(1)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Post {
  id             String   @id @default(uuid())
  projectId      String
  title          String
  slug           String   @unique
  contentPublic  String?
  contentTeaser  String?
  contentLevel1  String?
  contentPremium String?
  minTierLevel   Int      @default(2)
  isEarlyAccess  Boolean  @default(false)
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id])
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  stripeSubscriptionId String   @unique
  status               String
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id])
}

model Donation {
  id              String   @id @default(uuid())
  userId          String
  amount          Int
  currency        String   @default("EUR")
  stripePaymentId String   @unique
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model UserProjectAccess {
  id         String    @id @default(uuid())
  userId     String
  projectId  String
  tierLevel  Int
  accessType String
  grantedAt  DateTime  @default(now())
  expiresAt  DateTime?
  project    Project   @relation(fields: [projectId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([userId, projectId])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  projectId       String
  amount          Int
  currency        String   @default("EUR")
  type            String
  stripePaymentId String   @unique
  status          String
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model Tip {
  id              String   @id @default(uuid())
  userId          String
  amount          Int      // Amount in cents
  currency        String   @default("EUR")
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Comment {
  id         String   @id @default(uuid())
  text       String
  imageUrl   String?
  authorId   String
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Polymorphic fields
  entityId   String   // The ID of the thing being commented on (Project, Post, etc.)
  entityType String   // The type of the thing (e.g., 'PROJECT', 'POST')

  // Self-relation for replies
  parentId   String?
  parent     Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")

  likes      CommentLike[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([entityId])
  @@index([entityType])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
}

enum UserTier {
  GUEST
  FREE
  OBSERVER
  WITNESS
  INSIDER
  ARCHITECT
}

enum SystemRole {
  ADMIN
  MODERATOR
  CREATOR
  USER
}
