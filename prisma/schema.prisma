generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(uuid())
  clerkUserId      String              @unique
  email            String              @unique
  tier             UserTier            @default(FREE)
  role             SystemRole          @default(USER)
  stripeCustomerId String?             @unique
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  creators         Creator[]
  donations        Donation[]
  payments         Payment[]
  subscriptions    Subscription[]
  projectAccess    UserProjectAccess[]
}

model Creator {
  id              String    @id @default(uuid())
  userId          String
  slug            String    @unique
  name            String
  bio             String?
  isApproved      Boolean   @default(false)
  stripeConnectId String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  projects        Project[]
}

model Project {
  id              String              @id @default(uuid())
  creatorId       String
  title           String
  slug            String              @unique
  goalAmount      Int
  collectedAmount Int                 @default(0)
  status          String              @default("draft")
  publishedAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  payments        Payment[]
  posts           Post[]
  creator         Creator             @relation(fields: [creatorId], references: [id])
  tiers           Tier[]
  projectAccess   UserProjectAccess[]
}

model Tier {
  id            String    @id @default(uuid())
  projectId     String
  level         Int
  name          String
  description   String?
  priceOneTime  Int
  stripePriceId String?   @unique
  maxSlots      Int?
  slotsTaken    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]
  project       Project   @relation(fields: [projectId], references: [id])
}

model Post {
  id             String   @id @default(uuid())
  projectId      String
  title          String
  slug           String   @unique
  contentPublic  String?
  contentTeaser  String?
  contentLevel1  String?
  contentPremium String?
  minTierLevel   Int      @default(2)
  isEarlyAccess  Boolean  @default(false)
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id])
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  stripeSubscriptionId String   @unique
  status               String
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  user                 User     @relation(fields: [userId], references: [id])
}

model Donation {
  id              String   @id @default(uuid())
  userId          String
  amount          Int
  currency        String   @default("EUR")
  stripePaymentId String   @unique
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model UserProjectAccess {
  id         String    @id @default(uuid())
  userId     String
  projectId  String
  tierLevel  Int
  accessType String
  grantedAt  DateTime  @default(now())
  expiresAt  DateTime?
  project    Project   @relation(fields: [projectId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([userId, projectId])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  projectId       String
  tierId          String?
  amount          Int
  currency        String   @default("EUR")
  type            String
  stripePaymentId String   @unique
  status          String
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id])
  tier            Tier?    @relation(fields: [tierId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

enum UserTier {
  GUEST
  FREE
  OBSERVER
  WITNESS
  INSIDER
  ARCHITECT
}

enum SystemRole {
  ADMIN
  MODERATOR
  CREATOR
  USER
}
